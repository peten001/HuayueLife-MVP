{
  "name": "@huayue-life/merchant-cashier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.json && vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:ui": "node scripts/verify-ui.mjs",
    "test:watch": "vitest",
    "screenshots": "node scripts/capture-ui.mjs",
    "screenshots:refine": "node scripts/capture-refine-ui.mjs",
    "screenshots:brand-refine": "node scripts/capture-brand-refine-ui.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "pinia": "^2.2.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.18.2",
    "vite": "6.0.6",
    "vitest": "^3.0.5",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "2.2.0"
  }
