<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/connector_setup_title"
            android:textColor="@color/terminal_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/close_connector_setup_button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/diagnostics_close" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/connector_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/diagnostics_panel_background"
                android:fontFamily="monospace"
                android:padding="12dp"
                android:textColor="@color/terminal_text_primary"
                android:textIsSelectable="true"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/connector_pairing_section"
                android:textColor="@color/terminal_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/pairing_payload_input"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1.4"
                    android:autofillHints=""
                    android:hint="@string/connector_pairing_payload_hint"
                    android:importantForAutofill="no"
                    android:inputType="textPassword"
                    android:maxLength="96"
                    android:singleLine="true" />

                <EditText
                    android:id="@+id/terminal_name_input"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:hint="@string/connector_terminal_name_hint"
                    android:importantForAutofill="no"
                    android:inputType="textCapSentences"
                    android:maxLength="80"
                    android:singleLine="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pair_terminal_button"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/connector_pair_button" />
            </LinearLayout>

            <TextView
                android:id="@+id/pairing_result_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/connector_pairing_security_note"
                android:textColor="@color/terminal_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/connector_controls_section"
                android:textColor="@color/terminal_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/connector_enabled_switch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/connector_enabled_label" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/automatic_printing_switch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/connector_auto_enabled_label" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/open_usb_setup_button"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="@string/connector_open_usb_setup" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/refresh_connector_status_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/connector_refresh_status" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/clear_local_pairing_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/connector_clear_local_pairing" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/connector_safety_note"
                android:textColor="@color/terminal_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
