<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/usb_diagnostics_title"
                android:textColor="@color/terminal_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/device_summary_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/terminal_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/copy_usb_diagnostics_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/usb_copy_diagnostics" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/close_usb_diagnostics_button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="@string/diagnostics_close" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/usb_devices_section"
                android:textColor="@color/terminal_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/usb_device_spinner"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/terminal_primary"
                    android:contentDescription="@string/usb_select_device" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/refresh_usb_devices_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/usb_refresh_devices" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/request_usb_permission_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/usb_request_permission" />
            </LinearLayout>

            <TextView
                android:id="@+id/usb_device_details_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/diagnostics_panel_background"
                android:fontFamily="monospace"
                android:padding="12dp"
                android:textColor="@color/terminal_text_primary"
                android:textIsSelectable="true"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/usb_endpoint_section"
                android:textColor="@color/terminal_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/usb_endpoint_spinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:backgroundTint="@color/terminal_primary"
                android:contentDescription="@string/usb_select_endpoint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/usb_test_config_section"
                android:textColor="@color/terminal_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/usb_paper_width_label" />

                <Spinner
                    android:id="@+id/paper_width_spinner"
                    android:layout_width="180dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp" />

                <EditText
                    android:id="@+id/custom_print_dots_input"
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:hint="@string/usb_custom_dots_hint"
                    android:importantForAutofill="no"
                    android:inputType="number"
                    android:maxLength="4"
                    android:singleLine="true"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="@string/usb_cut_mode_label" />

                <Spinner
                    android:id="@+id/cut_mode_spinner"
                    android:layout_width="190dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/threshold_label"
                    android:layout_width="170dp"
                    android:layout_height="wrap_content" />

                <SeekBar
                    android:id="@+id/image_threshold_seekbar"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:max="255"
                    android:progress="160" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/test_usb_connection_button"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="@string/usb_test_connection" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/print_ascii_test_button"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/usb_print_ascii" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/print_image_test_button"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/usb_print_image" />

                <ProgressBar
                    android:id="@+id/usb_action_progress"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="12dp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/usb_action_result_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/diagnostics_panel_background"
                android:fontFamily="monospace"
                android:minHeight="72dp"
                android:padding="12dp"
                android:text="@string/usb_no_test_result"
                android:textColor="@color/terminal_text_primary"
                android:textIsSelectable="true"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
