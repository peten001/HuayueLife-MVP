  pairingCodeHash        String?                  @map("pairing_code_hash") @db.VarChar(64)
  pairingExpiresAt       DateTime?                @map("pairing_expires_at")
  pairingAttemptCount    Int                      @default(0) @map("pairing_attempt_count")
  pairingMaxAttempts     Int                      @default(5) @map("pairing_max_attempts")
  tokenHash              String?                  @unique(map: "uq_mt_token_hash") @map("token_hash") @db.VarChar(64)
  tokenVersion           Int                      @default(0) @map("token_version")
