  merchantId          BigInt                      @map("merchant_id")
  customerId          BigInt                      @map("customer_id")
  status              OrderChatConversationStatus @default(ACTIVE)
  customerUnreadCount Int                         @default(0) @map("customer_unread_count")
  merchantUnreadCount Int                         @default(0) @map("merchant_unread_count")
  lastMessageId       BigInt?                     @unique @map("last_message_id")
  lastMessageAt       DateTime?                   @map("last_message_at")
  customerLastReadAt  DateTime?                   @map("customer_last_read_at")
  merchantLastReadAt  DateTime?                   @map("merchant_last_read_at")
