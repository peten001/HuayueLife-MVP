  attempts     PrintAttempt[]

  @@index([merchantId, status], map: "ix_mt_merchant_status")
  @@index([merchantId, lastSeenAt], map: "ix_mt_merchant_seen")
  @@index([merchantId, boundPrinterId], map: "ix_mt_merchant_printer")
  @@index([pairingExpiresAt], map: "ix_mt_pairing_expiry")
  @@index([tokenExpiresAt], map: "ix_mt_token_expiry")
  @@map("merchant_terminals")
}

model PrintingAuditLog {
