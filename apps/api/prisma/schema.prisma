model OrderChatMessage {
  id             BigInt              @id @default(autoincrement())
  conversationId BigInt              @map("conversation_id")
  orderId        BigInt              @map("order_id")
  senderType     OrderChatSenderType @map("sender_type")
  senderId       BigInt              @map("sender_id")
