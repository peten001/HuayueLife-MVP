generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum MerchantType {
  RESTAURANT
  MILK_TEA
  FRUIT
  FLOWER
  CAKE
}

enum MerchantStatus {
  PENDING
  ACTIVE
  DISABLED
  DELETED
}

enum MerchantMode {
  DISPLAY
  MANAGED
  DISPLAY_ONLY
  PRODUCT_DISPLAY
  ONLINE_ORDER
  QR_ORDER
}

enum MerchantClaimStatus {
  UNCLAIMED
  CLAIMED
}

enum StaffRole {
  OWNER
  MANAGER
  STAFF
}

enum StaffStatus {
  ACTIVE
  DISABLED
}

enum ProductType {
  FOOD
  DRINK
  FRUIT
  FLOWER
  CAKE
}

enum ProductStatus {
  DRAFT
  ON_SALE
  SOLD_OUT
  OFF_SALE
}

enum TableStatus {
  ACTIVE
  DISABLED
}

enum TableSessionStatus {
  OPEN
  CLOSED
}

enum OrderType {
  DINE_IN
  PICKUP
  DELIVERY
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum OrderStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  PREPARING
  READY
  DELIVERING
  COMPLETED
  CANCELLED
}

enum SettlementStatus {
  UNSETTLED
  SETTLED
}

enum OperatorType {
  USER
  MERCHANT_STAFF
  SYSTEM
}

enum OrderChatConversationStatus {
  ACTIVE
  CLOSED
}

enum OrderChatSenderType {
  CUSTOMER
  MERCHANT
  SYSTEM
}

enum PrinterType {
  NETWORK
}

enum PrinterUsageType {
  FRONT_DESK
  KITCHEN
  BAR
  GENERAL
}

enum PrinterEncoding {
  UTF8
  GBK
  CP1258
}

enum PaperWidth {
  WIDTH_58
  WIDTH_80
}

enum PrintLanguage {
  zh
  vi
  en
}

enum PrinterStatus {
  UNKNOWN
  ONLINE
  OFFLINE
}

enum PrintLogStatus {
  PENDING
  PRINTING
  SUCCESS
  FAILED
}

enum PrintLogOperator {
  SYSTEM
  MERCHANT
}

enum PrinterChannelType {
  LOCAL_LAN_ESCPOS
  LOCAL_USB_ESCPOS
  CLOUD_FEIE
  CLOUD_XINYE
  CLOUD_GPRINTER
  BUILTIN_SUNMI
  BUILTIN_IMIN
}

enum PrintingPaperWidth {
  MM58
  MM80
}

enum PrinterPurpose {
  FRONT_DESK
  KITCHEN
  BAR
  LABEL
}

enum PrintingPrinterStatus {
  UNVERIFIED
  UNKNOWN
  ONLINE
  OFFLINE
  ERROR
}

enum ReceiptType {
  ORDER_CUSTOMER
  TABLE_BILL
}

enum ReceiptLanguageMode {
  MERCHANT_DEFAULT
  ZH
  VI
  EN
}

enum PrintTriggerEvent {
  ORDER_ACCEPTED
  ORDER_COMPLETED
  MANUAL
}

enum PrintJobSource {
  AUTOMATIC
  MANUAL
  MANUAL_REPRINT
  TEST
}

enum PrintJobStatus {
  PENDING
  CLAIMED
  PRINTING
  SUCCEEDED
  RETRY_WAIT
  FAILED
  CANCELLED
}

enum PrintTriggerOutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum PrintAttemptExecutorType {
  TERMINAL
  SERVER_ADAPTER
}

enum PrintAttemptResult {
  SUCCEEDED
  FAILED
  OUTCOME_UNKNOWN
}

enum MerchantTerminalPlatform {
  ANDROID
  WEB
  SERVER
}

enum MerchantTerminalStatus {
  UNPAIRED
  ACTIVE
  DISABLED
  REVOKED
}

model User {
  id          BigInt     @id @default(autoincrement())
  openid      String     @unique @db.VarChar(64)
  unionid     String?    @unique @db.VarChar(64)
  nickname    String?    @db.VarChar(64)
  avatarUrl   String?    @map("avatar_url") @db.VarChar(500)
  phone       String?    @db.VarChar(32)
  status      UserStatus @default(ACTIVE)
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  carts                  Cart[]
  orders                 Order[]
  orderChatConversations OrderChatConversation[]
  operatedStatusLogs     OrderStatusLog[]        @relation("UserStatusLogOperator")
  claimedMerchants       Merchant[]              @relation("MerchantOwnerUser")

  @@map("users")
}

model Merchant {
  id                       BigInt              @id @default(autoincrement())
  businessTypeId           BigInt?             @map("business_type_id")
  nameZh                   String              @map("name_zh") @db.VarChar(120)
  nameVi                   String?             @map("name_vi") @db.VarChar(120)
  nameEn                   String?             @map("name_en") @db.VarChar(120)
  merchantType             MerchantType        @default(RESTAURANT) @map("merchant_type")
  merchantMode             MerchantMode        @default(DISPLAY_ONLY) @map("merchant_mode")
  claimStatus              MerchantClaimStatus @default(UNCLAIMED) @map("claim_status")
  ownerUserId              BigInt?             @map("owner_user_id")
  logoUrl                  String?             @map("logo_url") @db.VarChar(500)
  coverUrl                 String?             @map("cover_url") @db.VarChar(500)
  contactName              String              @map("contact_name") @db.VarChar(64)
  contactPhone             String              @map("contact_phone") @db.VarChar(32)
  province                 String              @db.VarChar(80)
  city                     String              @db.VarChar(80)
  district                 String?             @db.VarChar(80)
  addressDetail            String              @map("address_detail") @db.VarChar(255)
  addressZh                String?             @map("address_zh") @db.VarChar(255)
  addressVi                String?             @map("address_vi") @db.VarChar(255)
  addressEn                String?             @map("address_en") @db.VarChar(255)
  latitude                 Decimal             @db.Decimal(10, 7)
  longitude                Decimal             @db.Decimal(10, 7)
  businessHours            Json                @map("business_hours")
  openingHoursText         String?             @map("opening_hours_text") @db.VarChar(255)
  notice                   String?             @db.Text
  descriptionZh            String?             @map("description_zh") @db.Text
  descriptionVi            String?             @map("description_vi") @db.Text
  descriptionEn            String?             @map("description_en") @db.Text
  minimumDeliveryAmountVnd BigInt              @default(0) @map("minimum_delivery_amount_vnd")
  deliveryFeeVnd           BigInt              @default(0) @map("delivery_fee_vnd")
  deliveryRadiusKm         Decimal             @default(0) @map("delivery_radius_km") @db.Decimal(5, 2)
  dineInEnabled            Boolean             @default(true) @map("dine_in_enabled")
  pickupEnabled            Boolean             @default(true) @map("pickup_enabled")
  deliveryEnabled          Boolean             @default(false) @map("delivery_enabled")
  isVisibleOnClient        Boolean             @default(true) @map("is_visible_on_client")
  reportFeatureEnabled     Boolean             @default(false) @map("report_feature_enabled")
  printingEnabled          Boolean             @default(false) @map("printing_enabled")
  homepageCategoryKeys     String              @default("[]") @map("homepage_category_keys") @db.VarChar(255)
  manualPopular            Boolean             @default(false) @map("manual_popular")
  sortOrder                Int                 @default(0) @map("sort_order")
  isNew                    Boolean             @default(false) @map("is_new")
  recommendedAt            DateTime?           @map("recommended_at")
  status                   MerchantStatus      @default(ACTIVE)
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  businessType           MerchantBusinessType?   @relation(fields: [businessTypeId], references: [id], onDelete: SetNull)
  ownerUser              User?                   @relation("MerchantOwnerUser", fields: [ownerUserId], references: [id], onDelete: SetNull)
  staff                  MerchantStaff[]
  categories             Category[]
  products               Product[]
  tables                 DiningTable[]
  tableSessions          TableSession[]
  carts                  Cart[]
  orders                 Order[]
  orderChatConversations OrderChatConversation[]
  printerSettings        PrinterSetting[]
  printLogs              PrintLog[]
  printers               Printer[]
  receiptTemplates       ReceiptTemplate[]
  printRules             PrintRule[]
  printJobs              PrintJob[]
  printTriggerOutbox     PrintTriggerOutbox[]
  merchantTerminals      MerchantTerminal[]
  printingAuditLogs      PrintingAuditLog[]
  merchantReportSetting  MerchantReportSetting?
  dailyReportLogs        DailyReportLog[]
  promotionTags          MerchantPromotionTag[]
  capabilities           MerchantCapability[]
  images                 MerchantImage[]

  @@index([status])
  @@index([province, city, status])
  @@index([latitude, longitude])
  @@index([businessTypeId, status])
  @@index([merchantMode, status])
  @@index([sortOrder])
  @@map("merchants")
}

model MerchantBusinessType {
  id                  BigInt       @id @default(autoincrement())
  parentId            BigInt?      @map("parent_id")
  code                String       @unique @db.VarChar(64)
  nameZh              String       @map("name_zh") @db.VarChar(80)
  nameVi              String?      @map("name_vi") @db.VarChar(80)
  nameEn              String?      @map("name_en") @db.VarChar(80)
  iconUrl             String?      @map("icon_url") @db.VarChar(500)
  level               Int          @default(1)
  path                String?      @db.VarChar(255)
  sortOrder           Int          @default(0) @map("sort_order")
  showOnHome          Boolean      @default(true) @map("show_on_home")
  enabled             Boolean      @default(true)
  defaultMerchantMode MerchantMode @default(DISPLAY_ONLY) @map("default_merchant_mode")
  defaultCapabilities Json?        @map("default_capabilities")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  parent    MerchantBusinessType?  @relation("BusinessTypeTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  MerchantBusinessType[] @relation("BusinessTypeTree")
  merchants Merchant[]

  @@index([parentId, sortOrder])
  @@index([enabled, showOnHome, sortOrder])
  @@map("merchant_business_types")
}

model PromotionTag {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique @db.VarChar(64)
  nameZh      String   @map("name_zh") @db.VarChar(80)
  nameVi      String?  @map("name_vi") @db.VarChar(80)
  nameEn      String?  @map("name_en") @db.VarChar(80)
  iconUrl     String?  @map("icon_url") @db.VarChar(500)
  iconText    String?  @map("icon_text") @db.VarChar(16)
  color       String?  @db.VarChar(32)
  description String?  @db.VarChar(255)
  sortOrder   Int      @default(0) @map("sort_order")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  merchants MerchantPromotionTag[]

  @@index([enabled, sortOrder])
  @@map("promotion_tags")
}

model Capability {
  id           BigInt   @id @default(autoincrement())
  code         String   @unique @db.VarChar(64)
  nameZh       String   @map("name_zh") @db.VarChar(80)
  nameVi       String?  @map("name_vi") @db.VarChar(80)
  nameEn       String?  @map("name_en") @db.VarChar(80)
  groupCode    String   @default("DISPLAY") @map("group_code") @db.VarChar(32)
  groupNameZh  String   @default("展示能力") @map("group_name_zh") @db.VarChar(80)
  groupNameVi  String?  @map("group_name_vi") @db.VarChar(80)
  groupNameEn  String?  @map("group_name_en") @db.VarChar(80)
  enabled      Boolean  @default(true)
  defaultValue Boolean  @default(false) @map("default_value")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  merchants MerchantCapability[]

  @@index([enabled, sortOrder])
  @@map("capabilities")
}

model MerchantPromotionTag {
  merchantId     BigInt   @map("merchant_id")
  promotionTagId BigInt   @map("promotion_tag_id")
  createdAt      DateTime @default(now()) @map("created_at")

  merchant     Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  promotionTag PromotionTag @relation(fields: [promotionTagId], references: [id], onDelete: Cascade)

  @@id([merchantId, promotionTagId])
  @@index([promotionTagId])
  @@map("merchant_promotion_tags")
}

model MerchantCapability {
  merchantId   BigInt   @map("merchant_id")
  capabilityId BigInt   @map("capability_id")
  isEnabled    Boolean  @default(false) @map("is_enabled")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  merchant   Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([merchantId, capabilityId])
  @@index([capabilityId])
  @@map("merchant_capabilities")
}

model MerchantImage {
  id         BigInt   @id @default(autoincrement())
  merchantId BigInt   @map("merchant_id")
  imageType  String   @map("image_type") @db.VarChar(32)
  imageUrl   String   @map("image_url") @db.VarChar(500)
  titleZh    String?  @map("title_zh") @db.VarChar(120)
  titleVi    String?  @map("title_vi") @db.VarChar(120)
  titleEn    String?  @map("title_en") @db.VarChar(120)
  sortOrder  Int      @default(0) @map("sort_order")
  isVisible  Boolean  @default(true) @map("is_visible")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, imageType, isVisible, sortOrder])
  @@map("merchant_images")
}

model MerchantReportSetting {
  id            BigInt   @id @default(autoincrement())
  merchantId    BigInt   @unique @map("merchant_id")
  enabled       Boolean  @default(false)
  zaloRecipient String?  @map("zalo_recipient") @db.VarChar(120)
  pushTime      String   @default("22:00") @map("push_time") @db.VarChar(5)
  language      String   @default("zh") @db.VarChar(8)
  aiSuggestions Boolean  @default(false) @map("ai_suggestions")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("merchant_report_settings")
}

model PlatformSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(120)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model MerchantStaff {
  id                 BigInt      @id @default(autoincrement())
  merchantId         BigInt      @map("merchant_id")
  username           String      @db.VarChar(64)
  passwordHash       String      @map("password_hash") @db.VarChar(255)
  mustChangePassword Boolean     @default(false) @map("must_change_password")
  displayName        String      @map("display_name") @db.VarChar(64)
  role               StaffRole   @default(STAFF)
  status             StaffStatus @default(ACTIVE)
  lastLoginAt        DateTime?   @map("last_login_at")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  merchant           Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  operatedStatusLogs OrderStatusLog[]   @relation("StaffStatusLogOperator")
  createdOrders      Order[]            @relation("StaffCreatedOrders")
  createdPrintJobs   PrintJob[]         @relation("PrintJobCreatedBy")
  printingAuditLogs  PrintingAuditLog[] @relation("PrintingAuditActor")

  @@unique([merchantId, username])
  @@index([merchantId, status])
  @@map("merchant_staff")
}

model Category {
  id         BigInt   @id @default(autoincrement())
  merchantId BigInt   @map("merchant_id")
  nameZh     String   @map("name_zh") @db.VarChar(80)
  nameVi     String?  @map("name_vi") @db.VarChar(80)
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([merchantId, isActive, sortOrder])
  @@map("categories")
}

model Product {
  id          BigInt        @id @default(autoincrement())
  merchantId  BigInt        @map("merchant_id")
  categoryId  BigInt        @map("category_id")
  nameZh      String        @map("name_zh") @db.VarChar(120)
  nameVi      String?       @map("name_vi") @db.VarChar(120)
  productType ProductType   @default(FOOD) @map("product_type")
  description String?       @db.Text
  imageUrl    String?       @map("image_url") @db.VarChar(500)
  priceVnd    BigInt        @map("price_vnd")
  sortOrder   Int           @default(0) @map("sort_order")
  status      ProductStatus @default(DRAFT)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  merchant   Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([merchantId, categoryId, status, sortOrder])
  @@map("products")
}

model DiningTable {
  id         BigInt      @id @default(autoincrement())
  merchantId BigInt      @map("merchant_id")
  tableNo    String      @map("table_no") @db.VarChar(32)
  tableName  String?     @map("table_name") @db.VarChar(64)
  qrToken    String      @unique @map("qr_token") @db.VarChar(64)
  qrVersion  Int         @default(1) @map("qr_version")
  status     TableStatus @default(ACTIVE)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  merchant      Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  carts         Cart[]
  orders        Order[]
  tableSessions TableSession[]

  @@unique([merchantId, tableNo])
  @@index([merchantId, status])
  @@map("dining_tables")
}

model TableSession {
  id          BigInt             @id @default(autoincrement())
  merchantId  BigInt             @map("merchant_id")
  tableId     BigInt             @map("table_id")
  openTableId BigInt?            @unique @map("open_table_id")
  sessionNo   String             @unique @map("session_no") @db.VarChar(32)
  status      TableSessionStatus @default(OPEN)
  openedAt    DateTime           @default(now()) @map("opened_at")
  closedAt    DateTime?          @map("closed_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  merchant  Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  table     DiningTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  orders    Order[]
  printJobs PrintJob[]

  @@index([merchantId, status])
  @@index([tableId, openedAt])
  @@index([merchantId, openedAt])
  @@map("table_sessions")
}

model Cart {
  id         BigInt     @id @default(autoincrement())
  userId     BigInt     @map("user_id")
  merchantId BigInt     @map("merchant_id")
  tableId    BigInt?    @map("table_id")
  orderType  OrderType  @map("order_type")
  status     CartStatus @default(ACTIVE)
  expiresAt  DateTime   @map("expires_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  table    DiningTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  items    CartItem[]

  @@index([userId, merchantId, orderType, status])
  @@index([expiresAt])
  @@map("carts")
}

model CartItem {
  id        BigInt   @id @default(autoincrement())
  cartId    BigInt   @map("cart_id")
  productId BigInt   @map("product_id")
  quantity  Int
  remark    String   @default("") @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId, remark])
  @@map("cart_items")
}

model Order {
  id                BigInt           @id @default(autoincrement())
  orderNo           String           @unique @map("order_no") @db.VarChar(32)
  idempotencyKey    String           @map("idempotency_key") @db.VarChar(64)
  userId            BigInt?          @map("user_id")
  createdByStaffId  BigInt?          @map("created_by_staff_id")
  merchantId        BigInt           @map("merchant_id")
  tableId           BigInt?          @map("table_id")
  tableSessionId    BigInt?          @map("table_session_id")
  tableNoSnapshot   String?          @map("table_no_snapshot") @db.VarChar(32)
  orderType         OrderType        @map("order_type")
  status            OrderStatus      @default(PENDING_ACCEPTANCE)
  contactName       String?          @map("contact_name") @db.VarChar(64)
  contactPhone      String?          @map("contact_phone") @db.VarChar(32)
  deliveryAddress   String?          @map("delivery_address") @db.VarChar(255)
  deliveryLatitude  Decimal?         @map("delivery_latitude") @db.Decimal(10, 7)
  deliveryLongitude Decimal?         @map("delivery_longitude") @db.Decimal(10, 7)
  customerRemark    String?          @map("customer_remark") @db.VarChar(500)
  itemAmountVnd     BigInt           @map("item_amount_vnd")
  deliveryFeeVnd    BigInt           @default(0) @map("delivery_fee_vnd")
  totalAmountVnd    BigInt           @map("total_amount_vnd")
  settlementStatus  SettlementStatus @default(UNSETTLED) @map("settlement_status")
  acceptedAt        DateTime?        @map("accepted_at")
  readyAt           DateTime?        @map("ready_at")
  completedAt       DateTime?        @map("completed_at")
  cancelledAt       DateTime?        @map("cancelled_at")
  cancelReason      String?          @map("cancel_reason") @db.VarChar(255)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  user               User?                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdByStaff     MerchantStaff?         @relation("StaffCreatedOrders", fields: [createdByStaffId], references: [id], onDelete: Restrict, map: "fk_orders_created_by_staff")
  merchant           Merchant               @relation(fields: [merchantId], references: [id])
  table              DiningTable?           @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tableSession       TableSession?          @relation(fields: [tableSessionId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  statusLogs         OrderStatusLog[]
  chatConversation   OrderChatConversation?
  chatMessages       OrderChatMessage[]
  printLogs          PrintLog[]
  printJobs          PrintJob[]
  printTriggerOutbox PrintTriggerOutbox[]

  @@unique([userId, idempotencyKey])
  @@unique([merchantId, createdByStaffId, idempotencyKey], map: "uq_orders_staff_idempotency")
  @@index([merchantId, status, createdAt])
  @@index([userId, createdAt])
  @@index([createdByStaffId, createdAt], map: "ix_orders_staff_created")
  @@index([tableSessionId])
  @@map("orders")
}

model OrderItem {
  id                    BigInt   @id @default(autoincrement())
  orderId               BigInt   @map("order_id")
  productId             BigInt?  @map("product_id")
  productNameZhSnapshot String   @map("product_name_zh_snapshot") @db.VarChar(120)
  imageUrlSnapshot      String?  @map("image_url_snapshot") @db.VarChar(500)
  unitPriceVnd          BigInt   @map("unit_price_vnd")
  quantity              Int
  subtotalVnd           BigInt   @map("subtotal_vnd")
  remark                String?  @db.VarChar(200)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
