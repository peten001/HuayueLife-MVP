  tokenExpiresAt         DateTime?                @map("token_expires_at")
  pairedAt               DateTime?                @map("paired_at")
  configVersion          Int                      @default(0) @map("config_version")
  resetUsbRequestedAt    DateTime?                @map("reset_usb_requested_at")
  resetUsbAcknowledgedAt DateTime?                @map("reset_usb_acknowledged_at")
  appVersion             String?                  @map("app_version") @db.VarChar(64)
  lastSeenAt             DateTime?                @map("last_seen_at")
  lastErrorCode          String?                  @map("last_error_code") @db.VarChar(64)
  lastErrorMessage       String?                  @map("last_error_message") @db.VarChar(500)
  revokedAt              DateTime?                @map("revoked_at")
