  rules              PrintRule[]
  jobs               PrintJob[]
  printTriggerOutbox PrintTriggerOutbox[]

  @@unique([merchantId, name, version], map: "uq_receipt_template_version")
  @@index([merchantId, receiptType, enabled], map: "ix_rt_merchant_type_enabled")
  @@map("receipt_templates")
}

model PrintRule {
  id                BigInt            @id @default(autoincrement())
  merchantId        BigInt            @map("merchant_id")
  name              String            @db.VarChar(80)
  orderType         OrderType?        @map("order_type")
  triggerEvent      PrintTriggerEvent @map("trigger_event")
  receiptType       ReceiptType       @map("receipt_type")
  printerId         BigInt            @map("printer_id")
  receiptTemplateId BigInt?           @map("receipt_template_id")
  copies            Int               @default(1)
  autoPrint         Boolean           @default(false) @map("auto_print")
  enabled           Boolean           @default(false)
  priority          Int               @default(100)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  merchant           Merchant             @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  printer            Printer              @relation(fields: [printerId], references: [id], onDelete: Restrict)
  receiptTemplate    ReceiptTemplate?     @relation(fields: [receiptTemplateId], references: [id], onDelete: Restrict)
  jobs               PrintJob[]
  printTriggerOutbox PrintTriggerOutbox[]

  @@index([merchantId, enabled, triggerEvent], map: "ix_pr_merchant_enabled_event")
  @@index([printerId, enabled], map: "ix_pr_printer_enabled")
  @@index([receiptTemplateId], map: "ix_pr_template")
  @@map("print_rules")
}

/// Durable transactional outbox for automatic-print intent. A row is created
/// in the same transaction as the corresponding OrderStatusLog. It freezes the
/// selected rule routing metadata at event time; PrintJob remains the execution
/// source of truth after processing.
model PrintTriggerOutbox {
  id                BigInt                   @id @default(autoincrement())
  merchantId        BigInt                   @map("merchant_id")
  orderId           BigInt                   @map("order_id")
  orderStatusLogId  BigInt                   @map("order_status_log_id")
  printRuleId       BigInt                   @map("print_rule_id")
  printerId         BigInt                   @map("printer_id")
  receiptTemplateId BigInt?                  @map("receipt_template_id")
  eventKey          String                   @unique(map: "uq_pto_event_key") @map("event_key") @db.VarChar(191)
  triggerEvent      PrintTriggerEvent        @map("trigger_event")
  ruleVersion       String                   @map("rule_version") @db.VarChar(64)
  receiptType       ReceiptType              @map("receipt_type")
  copies            Int                      @default(1)
  priority          Int                      @default(100)
  status            PrintTriggerOutboxStatus @default(PENDING)
  availableAt       DateTime                 @default(now()) @map("available_at")
  claimedAt         DateTime?                @map("claimed_at")
  leaseExpiresAt    DateTime?                @map("lease_expires_at")
  leaseVersion      Int                      @default(0) @map("lease_version")
  attemptCount      Int                      @default(0) @map("attempt_count")
  maxAttempts       Int                      @default(20) @map("max_attempts")
  processedAt       DateTime?                @map("processed_at")
  lastErrorCode     String?                  @map("last_error_code") @db.VarChar(64)
  lastErrorMessage  String?                  @map("last_error_message") @db.VarChar(500)
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  merchant        Merchant         @relation(fields: [merchantId], references: [id], onDelete: Restrict, map: "fk_pto_merchant")
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Restrict, map: "fk_pto_order")
  orderStatusLog  OrderStatusLog   @relation(fields: [orderStatusLogId], references: [id], onDelete: Restrict, map: "fk_pto_status_log")
  printRule       PrintRule        @relation(fields: [printRuleId], references: [id], onDelete: Restrict, map: "fk_pto_rule")
  printer         Printer          @relation(fields: [printerId], references: [id], onDelete: Restrict, map: "fk_pto_printer")
  receiptTemplate ReceiptTemplate? @relation(fields: [receiptTemplateId], references: [id], onDelete: Restrict, map: "fk_pto_template")

  @@index([merchantId, status, availableAt], map: "ix_pto_merchant_claim")
  @@index([status, leaseExpiresAt], map: "ix_pto_lease")
  @@index([orderId, createdAt], map: "ix_pto_order")
  @@index([orderStatusLogId], map: "ix_pto_status_log")
  @@index([printRuleId, createdAt], map: "ix_pto_rule")
  @@index([printerId], map: "ix_pto_printer")
  @@index([receiptTemplateId], map: "ix_pto_template")
  @@map("print_trigger_outbox")
}

model PrintJob {
  id                     BigInt            @id @default(autoincrement())
  merchantId             BigInt            @map("merchant_id")
  orderId                BigInt?           @map("order_id")
  tableSessionId         BigInt?           @map("table_session_id")
  printerId              BigInt            @map("printer_id")
  printRuleId            BigInt?           @map("print_rule_id")
  ruleVersion            String?           @map("rule_version") @db.VarChar(64)
  requestGroupId         String?           @map("request_group_id") @db.VarChar(64)
  copyIndex              Int               @default(1) @map("copy_index")
  copyCount              Int               @default(1) @map("copy_count")
  receiptTemplateId      BigInt?           @map("receipt_template_id")
  receiptTemplateVersion Int?              @map("receipt_template_version")
  receiptType            ReceiptType       @map("receipt_type")
  triggerEvent           PrintTriggerEvent @map("trigger_event")
  source                 PrintJobSource
  status                 PrintJobStatus    @default(PENDING)
  priority               Int               @default(100)
  dedupeKey              String?           @unique(map: "uq_print_jobs_dedupe") @map("dedupe_key") @db.VarChar(191)
  receiptSnapshot        Json              @map("receipt_snapshot")
  receiptSnapshotHash    String?           @map("receipt_snapshot_hash") @db.VarChar(64)
  availableAt            DateTime          @default(now()) @map("available_at")
  claimedAt              DateTime?         @map("claimed_at")
  leaseExpiresAt         DateTime?         @map("lease_expires_at")
  leaseVersion           Int               @default(0) @map("lease_version")
  claimedByTerminalId    BigInt?           @map("claimed_by_terminal_id")
  attemptCount           Int               @default(0) @map("attempt_count")
  maxAttempts            Int               @default(3) @map("max_attempts")
  retryBlocked           Boolean           @default(false) @map("retry_blocked")
  completedAt            DateTime?         @map("completed_at")
  cancelledAt            DateTime?         @map("cancelled_at")
  createdByStaffId       BigInt?           @map("created_by_staff_id")
  lastErrorCode          String?           @map("last_error_code") @db.VarChar(64)
  lastErrorMessage       String?           @map("last_error_message") @db.VarChar(500)
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  merchant        Merchant          @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  order           Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  tableSession    TableSession?     @relation(fields: [tableSessionId], references: [id], onDelete: SetNull)
  printer         Printer           @relation(fields: [printerId], references: [id], onDelete: Restrict)
  printRule       PrintRule?        @relation(fields: [printRuleId], references: [id], onDelete: Restrict)
  receiptTemplate ReceiptTemplate?  @relation(fields: [receiptTemplateId], references: [id], onDelete: Restrict)
  claimedBy       MerchantTerminal? @relation("PrintJobClaimedBy", fields: [claimedByTerminalId], references: [id], onDelete: SetNull)
  createdByStaff  MerchantStaff?    @relation("PrintJobCreatedBy", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  attempts        PrintAttempt[]

  @@index([merchantId, status, availableAt, priority], map: "ix_pj_claim")
  @@index([orderId, createdAt], map: "ix_pj_order")
  @@index([tableSessionId, createdAt], map: "ix_pj_table_session")
  @@index([printerId, createdAt], map: "ix_pj_printer")
  @@index([printRuleId, createdAt], map: "ix_pj_rule")
  @@index([requestGroupId, copyIndex], map: "ix_pj_request_group")
  @@index([claimedByTerminalId, status], map: "ix_pj_terminal_status")
  @@index([status, leaseExpiresAt], map: "ix_pj_lease")
  @@map("print_jobs")
}

model PrintAttempt {
  id              BigInt                   @id @default(autoincrement())
  jobId           BigInt                   @map("job_id")
  attemptNo       Int                      @map("attempt_no")
  executorType    PrintAttemptExecutorType @map("executor_type")
  terminalId      BigInt?                  @map("terminal_id")
  adapter         String                   @db.VarChar(80)
  startedAt       DateTime                 @default(now()) @map("started_at")
  finishedAt      DateTime?                @map("finished_at")
  result          PrintAttemptResult?
  errorCode       String?                  @map("error_code") @db.VarChar(64)
  errorMessage    String?                  @map("error_message") @db.VarChar(500)
  printerResponse String?                  @map("printer_response") @db.VarChar(500)
  appVersion      String?                  @map("app_version") @db.VarChar(64)
  networkInfo     Json?                    @map("network_info")
  contentHash     String?                  @map("content_hash") @db.VarChar(64)
  bytesWritten    Int?                     @map("bytes_written")
  createdAt       DateTime                 @default(now()) @map("created_at")

  job      PrintJob          @relation(fields: [jobId], references: [id], onDelete: Restrict)
  terminal MerchantTerminal? @relation(fields: [terminalId], references: [id], onDelete: SetNull)

  @@unique([jobId, attemptNo], map: "uq_pa_job_attempt")
  @@index([terminalId, startedAt], map: "ix_pa_terminal_started")
  @@index([result, startedAt], map: "ix_pa_result_started")
  @@map("print_attempts")
}

model MerchantTerminal {
  id                     BigInt                   @id @default(autoincrement())
  merchantId             BigInt                   @map("merchant_id")
