model Printer {
  id               BigInt                @id @default(autoincrement())
  merchantId       BigInt                @map("merchant_id")
  name             String                @db.VarChar(80)
  channelType      PrinterChannelType    @map("channel_type")
  paperWidth       PrintingPaperWidth    @default(MM80) @map("paper_width")
  purpose          PrinterPurpose        @default(FRONT_DESK)
  enabled          Boolean               @default(false)
  status           PrintingPrinterStatus @default(UNVERIFIED)
  connectionConfig Json                  @map("connection_config")
  capabilities     Json?
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  deletedAt        DateTime?             @map("deleted_at")

  merchant           Merchant             @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  rules              PrintRule[]
  jobs               PrintJob[]
  printTriggerOutbox PrintTriggerOutbox[]
  boundTerminal      MerchantTerminal?    @relation("TerminalBoundPrinter")

  @@index([merchantId, enabled], map: "ix_printer_merchant_enabled")
  @@index([merchantId, channelType], map: "ix_printer_merchant_channel")
  @@index([merchantId, deletedAt], map: "ix_printer_merchant_deleted")
  @@map("printers")
}

model ReceiptTemplate {
  id           BigInt              @id @default(autoincrement())
