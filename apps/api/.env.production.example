# Runtime
NODE_ENV="production"
PORT=3001

# MySQL 8
# Use a dedicated application user. URL-encode special characters in passwords.
DATABASE_URL="mysql://huayue_app:REPLACE_WITH_DB_PASSWORD@mysql.internal:3306/huayue_life_mvp"

# Authentication
# Generate at least 32 random bytes. Do not reuse development or test secrets.
JWT_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES"
JWT_EXPIRES_IN="7d"

# WeChat Mini Program
# Keep AppSecret on the API server only.
WECHAT_APP_ID="wx_REPLACE_WITH_REAL_APP_ID"
WECHAT_APP_SECRET="REPLACE_WITH_REAL_APP_SECRET"

# Public HTTPS QR entry. It must ultimately open the mini program scan flow.
MINIAPP_QR_ENTRY_URL="https://miniapp.example.com/scan"

# Only required when running prisma seed for a new pilot environment.
# Remove it from the runtime environment after seeding.
SEED_MERCHANT_PASSWORD="REPLACE_WITH_ONE_TIME_STRONG_PASSWORD"
