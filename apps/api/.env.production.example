# Runtime
NODE_ENV="production"
PORT=3001

# MySQL 8
# Use a dedicated application user. URL-encode special characters in passwords.
DATABASE_URL="mysql://huayue_app:REPLACE_WITH_DB_PASSWORD@mysql.internal:3306/huayue_life_mvp"

# Authentication
# Generate at least 32 random bytes. Do not reuse development or test secrets.
JWT_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES"
JWT_EXPIRES_IN="7d"

# Exact browser origins only; add the cashier origin only after DNS/TLS is
# confirmed. Do not use wildcard origins with credentials.
CORS_ALLOWED_ORIGINS="https://admin.huayueyouxuan.com,https://servicewechat.com"

# Printing cutover safety defaults. Keep legacy direct printing and the new
# automatic/execution paths disabled until their separate acceptance gates pass.
PRINTING_TASK_CENTER_ENABLED="true"
PRINTING_AUTO_CREATE_ENABLED="false"
PRINTING_EXECUTION_ENABLED="false"
LEGACY_PRINTING_ENABLED="false"

# Terminal credentials are independent from merchant JWTs. Generate this with
# `openssl rand -base64 48`, store it in the deployment secret manager, and do
# not rotate it without an explicit terminal re-pairing plan.
TERMINAL_AUTH_PEPPER=""
TERMINAL_TOKEN_TTL_DAYS="365"
TERMINAL_JOB_POLL_SECONDS="5"
TERMINAL_HEARTBEAT_SECONDS="20"

# WeChat Mini Program
# Keep AppSecret on the API server only.
WECHAT_APP_ID="your_app_id"
WECHAT_APP_SECRET="your_app_secret"

# Public base URL used to generate short QR links like https://api.example.com/t/xxx.
PUBLIC_QR_BASE_URL="https://api.example.com"

# Public HTTPS QR entry. It must ultimately open the mini program scan flow.
MINIAPP_QR_ENTRY_URL="https://miniapp.example.com/scan"

# Only required when running prisma seed for a new pilot environment.
# Remove it from the runtime environment after seeding.
SEED_MERCHANT_PASSWORD="REPLACE_WITH_ONE_TIME_STRONG_PASSWORD"
