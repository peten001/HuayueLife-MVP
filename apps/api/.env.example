NODE_ENV="development"
PORT=3001
DATABASE_URL="mysql://huayue:change-me@localhost:3307/huayue_life_mvp"
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_EXPIRES_IN="7d"
# Exact comma-separated browser origins. Native Android requests do not need one.
CORS_ALLOWED_ORIGINS="https://admin.huayueyouxuan.com,https://servicewechat.com"
PRINTING_TASK_CENTER_ENABLED="true"
PRINTING_AUTO_CREATE_ENABLED="false"
PRINTING_EXECUTION_ENABLED="false"
# Temporary rollback switch for the retired server-side Socket/TCP printer path.
# Never enable together with PRINTING_AUTO_CREATE_ENABLED.
LEGACY_PRINTING_ENABLED="false"
# Generate with: openssl rand -base64 48
TERMINAL_AUTH_PEPPER=""
TERMINAL_TOKEN_TTL_DAYS="365"
TERMINAL_JOB_POLL_SECONDS="5"
TERMINAL_HEARTBEAT_SECONDS="20"
WECHAT_APP_ID="your_app_id"
WECHAT_APP_SECRET="your_app_secret"
PUBLIC_QR_BASE_URL="https://api.example.com"
MINIAPP_QR_ENTRY_URL="https://example.com/scan"
SEED_MERCHANT_PASSWORD="ChangeMe123!"
