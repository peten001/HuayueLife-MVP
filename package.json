{
  "name": "huayue-life-mvp",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "dev:api": "corepack pnpm --filter @huayue-life/api start:dev",
    "dev:miniapp": "corepack pnpm --filter @huayue-life/miniapp dev:mp-weixin",
    "dev:merchant-admin": "corepack pnpm --filter @huayue-life/merchant-admin dev",
    "db:generate": "corepack pnpm --filter @huayue-life/api prisma:generate",
    "db:migrate": "corepack pnpm --filter @huayue-life/api prisma:migrate",
    "db:seed": "corepack pnpm --filter @huayue-life/api prisma:seed"
  }
}
